# LinkedIn Scraper Configuration

# Encryption key for storing sessions
# Change this to a random string for production
ENCRYPTION_KEY=dev-key-please-change-in-production

# Next.js Port (default: 3000)
PORT=3000

# Debug mode (set to true for verbose logging)
DEBUG=false

# Maximum profiles to click per scrape (1-5 recommended)
MAX_PROFILES=5

# Scroll distance before finding comments (pixels)
SCROLL_DISTANCE=3000

# Minimum delay between actions (milliseconds)
MIN_DELAY=500

# Maximum delay between actions (milliseconds)
MAX_DELAY=2000
